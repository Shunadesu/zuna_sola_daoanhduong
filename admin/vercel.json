{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "port": 4848,
  "env": {
    "VITE_API_URL": "@sola-admin-api-url"
  },
  "regions": ["sin1"],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://sola-api.vercel.app/api/:path*" }
  ]
}
