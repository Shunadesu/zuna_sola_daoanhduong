{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "env": {
    "VITE_API_URL": "https://sunnydemo.site"
  },
  "regions": ["sin1"],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://sunnydemo.site/api/:path*" },
    { "source": "/((?!api|_next|_vercel|.*\\..*).*)", "destination": "/index.html" }
  ]
}
