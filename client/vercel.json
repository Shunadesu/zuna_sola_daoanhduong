{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "env": {
    "VITE_API_URL": "https://sunnydemo.site"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://sunnydemo.site/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
